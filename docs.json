{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "XreatLabs",
  "colors": {
    "primary": "#FF8C42",
    "light": "#FFAB66",
    "dark": "#E5722D"
  },
  "logo": {
    "light": "/logo/xreatlabs-light.png",
    "dark": "/logo/xreatlabs-dark.png"
  },
  "favicon": "/favicon.png",
  "stylesheets": [
    "/styles.css"
  ],
  "topbarCtaButton": {
    "type": "github",
    "url": "https://github.com/XreatLabs"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Agent ready",
            "pages": [
              "agent-ready/prompt",
              "agent-ready/visibility",
              "agent-ready/contextual",
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://xreatlabs.space",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/XreatLabs",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:official@xreatlabs.space"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/XreatLabs",
      "linkedin": "https://linkedin.com/company/xreatlabs"
    }
  }
