{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "XreatLabs",
  "colors": {
    "primary": "#9B8EB4",
    "light": "#B8A8D1",
    "dark": "#7A6B9E",
    "background": {
      "light": "#FAF9FC",
      "dark": "#1A1820"
    }
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/xreatlabs-logo.png",
    "dark": "/logo/xreatlabs-logo.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/components",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "Agent ready",
            "pages": [
              "agent-ready/prompt",
              "agent-ready/visibility",
              "agent-ready/contextual",
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://xreatlabs.space",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/XreatLabs",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:official@xreatlabs.space"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/XreatLabs",
      "linkedin": "https://linkedin.com/company/xreatlabs"
    }
  },
  "integrations": {
    "intercom": ""
  }
}
